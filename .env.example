APP_NAME="ERPAsia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://erpasia.test

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dataerpasia
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=erpasia.test,*.erpasia.test,localhost:8000,localhost

CORS_ALLOWED_ORIGINS=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@erpasia.test"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Payment Gateway — Dynamic Multi-Provider (all via admin UI)
# ---------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# License v3 Pairing (whitelabel.co.id)
# ---------------------------------------------------------------------------
LICENSE_SERVER_URL=https://whitelabel.co.id
LICENSE_DEV_BYPASS=true
LICENSE_HEARTBEAT_INTERVAL=86400
LICENSE_HEARTBEAT_GRACE=604800

# ---------------------------------------------------------------------------
# Demo Accounts (for documentation only)
# ---------------------------------------------------------------------------
# Super Admin Panel: http://erpasia.test/super
#   super@erpasia.test / password
#
